{
  "name": "better-auth-razorpay",
  "author": "",
  "version": "2.0.5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamjasonkendrick/better-auth-razorpay.git"
  },
  "keywords": [
    "better-auth",
    "razorpay",
    "auth",
    "subscription",
    "payments",
    "billing",
    "saas",
    "nextjs",
    "typescript",
    "plugin",
    "authentication",
    "payment-gateway",
    "india",
    "inr",
    "webhook",
    "plans",
    "trial"
  ],
  "module": "dist/index.js",
  "description": "Razorpay plugin for Better Auth",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul",
    "lint:package": "npx --yes publint run --strict",
    "lint:types": "npx --yes @arethetypeswrong/cli --profile esm-only --pack .",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./react": {
      "dev-source": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ]
    }
  },
  "dependencies": {
    "defu": "^6.1.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "better-auth": "*",
    "razorpay": "^2.9.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "better-auth": "^1.2.10",
    "better-call": "^1.0.10",
    "razorpay": "^2.9.6",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
